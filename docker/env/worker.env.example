APP_TIMEZONE=America/Sao_Paulo

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=usuario_do_banco
DB_PASSWORD=senha_do_banco
DB_DATABASE=leiloeiros
DB_CONNECT_TIMEOUT=5
CONSULTA_DB_PREFIX=ferramenta_consulta_
CONSULTA_LEGACY_MYSQL_QUEUE_ENABLED=false

BIDMAP_USUARIOS_API_BASE_URL=http://localhost:8000/api/usuarios
BIDMAP_USUARIOS_API_TOKEN=coloque_o_token_aqui
BIDMAP_USUARIOS_API_AUTH_PREFIX=token
BIDMAP_USUARIOS_API_HOST_HEADER=
BIDMAP_USUARIOS_API_FOLLOW_REDIRECTS=true
BIDMAP_USUARIOS_API_FALLBACK_BASE_URL=http://127.0.0.1/api/usuarios
BIDMAP_USUARIOS_API_FALLBACK_HOST_HEADER=localhost
BIDMAP_USUARIOS_API_FALLBACK_FOLLOW_REDIRECTS=false
BIDMAP_CREDITOS_LOG_ENABLED=true
BIDMAP_CREDITOS_LOG_FILE=/var/www/html/storage/logs/creditos-api.log
BIDMAP_CREDITOS_API_TIMEOUT=5
BIDMAP_CREDITOS_API_CONNECT_TIMEOUT=3
BIDMAP_CREDITOS_SESSION_CACHE_TTL=30
BIDMAP_EXTRATO_SYNC_TTL=300
BIDMAP_CREDITOS_ALLOW_STATIC_FALLBACK=false
BIDMAP_CREDITOS_FALLBACK_USER_ID=
BIDMAP_CREDITOS_FALLBACK_SALDO=
BIDMAP_CREDITOS_ALLOW_TEST_USER=true
DADOS_PESSOAIS_TEST_USER_ID=1
DADOS_PESSOAIS_SKIP_CREDITOS=false

BIDMAP_CHECKOUT_CREDITOS_25=#
BIDMAP_CHECKOUT_CREDITOS_50=#
BIDMAP_CHECKOUT_CREDITOS_100=#

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=2.5
REDIS_READ_TIMEOUT=30
REDIS_QUEUE_PREFIX=bidmap
REDIS_PUBLISHER_RESERVATION_TTL=300
REDIS_PUBLISHER_LOG_IDLE_EVERY=60
REDIS_PUBLISHER_MAX_CYCLES=1200
REDIS_PUBLISHER_MAX_RUNTIME_SECONDS=3600
REDIS_PROCESSING_STALE_SECONDS=900
REDIS_WORKER_QUEUES=consultas:processos,consultas:pdf,consultas:pessoas,consultas:empresas
REDIS_WORKER_LOG_IDLE_EVERY=60
REDIS_WORKER_MAX_JOBS=500
REDIS_WORKER_MAX_RUNTIME_SECONDS=3600

# Filas usadas ao criar novos jobs no MySQL. Deixe os overrides vazios para usar os padroes.
CONSULTA_JOB_QUEUE_PROCESSOS=consultas:processos
CONSULTA_JOB_QUEUE_DETALHES_PROCESSO=
CONSULTA_JOB_QUEUE_PDF_PROCESSO=consultas:pdf
CONSULTA_JOB_QUEUE_DADOS_CPF=consultas:pessoas
CONSULTA_JOB_QUEUE_DADOS_CNPJ=consultas:empresas

# Worker Python experimental. Por padrao consome apenas uma fila de teste
# para nao disputar jobs reais com o worker PHP durante a migracao gradual.
PYTHON_WORKER_QUEUES=consultas:processos,consultas:pdf,consultas:pessoas,consultas:empresas
PYTHON_WORKER_SUPPORTED_TYPES=detalhes_processo,consulta_processos,pdf_processo,dados_cpf,dados_cnpj
PYTHON_WORKER_TIMEOUT=5
PYTHON_WORKER_MAX_JOBS=500
PYTHON_WORKER_MAX_RUNTIME=3600
PYTHON_WORKER_HTTP_TIMEOUT=60
PYTHON_WORKER_UNSUPPORTED_RETRY_SECONDS=900

